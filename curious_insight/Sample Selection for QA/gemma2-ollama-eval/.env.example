# This file serves as a template for environment variables needed for the project.
# You can copy this file to .env and fill in the required values.

# API endpoint for the Ollama service
OLLAMA_URL=http://localhost:11434/api

# Model name to be used
MODEL_NAME=gemma2:27b

# Input and output file paths
INPUT_FILE=/path/to/your/input_file.csv
OUTPUT_FILE=/path/to/your/output_file.csv

# Additional configurations can be added as needed.